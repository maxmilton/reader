{
  "name": "reader",
  "version": "0.3.0",
  "private": true,
  "description": "📖 Web page speed reader.",
  "homepage": "https://github.com/maxmilton/reader",
  "bugs": "https://github.com/maxmilton/reader/issues",
  "repository": "github:maxmilton/reader",
  "license": "MIT",
  "author": "Max Milton <max@2okki.com>",
  "type": "module",
  "imports": {
    "#*": "./src/*"
  },
  "scripts": {
    "build": "NODE_ENV=production bun build.ts",
    "dev": "NODE_ENV=development bun build.ts",
    "lint": "bun lint:fmt && bun lint:css && bun lint:js && bun lint:ts",
    "lint:css": "stylelint '**/*.{css,xcss}'",
    "lint:fmt": "biome check",
    "lint:js": "eslint",
    "lint:ts": "tsc --noEmit",
    "test": "bun test --only-failures",
    "test:ci": "bun test --coverage --randomize --rerun-each=3",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@ekscss/framework": "0.0.60",
    "@maxmilton/html-parser": "0.0.13",
    "bugbox": "0.0.4",
    "stage1": "0.10.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@eslint/js": "10.0.1",
    "@maxmilton/eslint-config": "0.3.2",
    "@maxmilton/stylelint-config": "0.4.3",
    "@maxmilton/test-utils": "0.0.15",
    "@playwright/test": "1.61.1",
    "@types/bun": "1.3.14",
    "@types/chrome": "0.2.2",
    "@types/csso": "5.0.4",
    "bun-plugin-ekscss": "0.0.3",
    "csso": "5.0.5",
    "ekscss": "0.0.23",
    "eslint": "10.6.0",
    "eslint-plugin-unicorn": "70.0.0",
    "happy-dom": "20.10.6",
    "lightningcss": "1.32.0",
    "purgecss": "8.0.0",
    "stylelint": "17.14.0",
    "stylelint-config-standard": "40.0.0",
    "terser": "5.48.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.1"
  }
}
